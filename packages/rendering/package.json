{
  "name": "@aardworx/wombat.rendering",
  "version": "0.7.2",
  "description": "WebGPU rendering layer for the Wombat TypeScript stack \u2014 RenderObject/RenderTask/runtime + window glue, port of Aardvark.Rendering's lower layers on top of WebGPU and wombat.shader.",
  "license": "MIT",
  "author": "krauthaufen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krauthaufen/wombat.rendering.git"
  },
  "homepage": "https://github.com/krauthaufen/wombat.rendering",
  "keywords": [
    "wombat",
    "aardvark",
    "webgpu",
    "rendering",
    "renderobject",
    "rendertask",
    "scenegraph",
    "shader"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./resources": {
      "types": "./dist/resources/index.d.ts",
      "import": "./dist/resources/index.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "import": "./dist/commands/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./window": {
      "types": "./dist/window/index.d.ts",
      "import": "./dist/window/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@aardworx/wombat.adaptive": "^0.2.2",
    "@aardworx/wombat.base": "^0.4.2",
    "@aardworx/wombat.shader": "^0.5.0"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69"
  },
  "publishConfig": {
    "access": "public"
  }
}
