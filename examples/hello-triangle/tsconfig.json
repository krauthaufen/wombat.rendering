{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "verbatimModuleSyntax": false,
    "plugins": [
      {
        "transform": "@boperators/plugin-tsc",
        "transformProgram": true
      },
      {
        "name": "@boperators/plugin-ts-language-server"
      }
    ]
  },
  "include": [
    "src/**/*.ts"
  ]
}
